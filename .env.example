# URL del backend .NET consumido por el BFF (Route Handlers), server-to-server.
# En producciÃ³n apunta al backend desplegado (Render/Railway/Azure).
BACKEND_URL=http://localhost:5080

# Habilita el widget de Wompi (012-wompi) en el frontend. Debe coincidir con
# Wompi:Enabled del backend; si estÃ¡ apagado, /api/payments/* devuelve 404.
NEXT_PUBLIC_WOMPI_ENABLED=false

# Modo local: salta el flujo OAuth y auto-autentica como usuario fijo
# (local@buildcv.dev con 1000 crÃ©ditos). Requiere que el backend tenga
# LocalAuth:Enabled=true (appsettings.Development.json) y que NEXTAUTH_SECRET
# coincida con NextAuth:SigningKey del backend.
# DÃ©jalo en "false" para builds de staging/producciÃ³n.
NEXT_PUBLIC_LOCAL_MODE=true

# 013.2-web-jwt-cookie â€” NextAuth.js (firmar/verificar session JWT).
# NEXTAUTH_SECRET DEBE coincidir byte-por-byte con JwtSettings:Secret del API
# (appsettings.json) o con NextAuth:SigningKey. MÃ­nimo 32 caracteres (HS256).
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=local-dev-secret-min-32-chars-for-testing-only

# Issuer y audience firmados en el JWT HS256 para /api/v1/auth/session.
# Deben coincidir con NextAuth:Issuer y NextAuth:Audience del backend.
NEXTAUTH_ISSUER=buildcv-web
NEXTAUTH_AUDIENCE=buildcv-api

# Google OAuth provider (NextAuth). Obtener en https://console.cloud.google.com/apis/credentials
# Redirect URI a registrar: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth provider (NextAuth). Obtener en https://www.linkedin.com/developers/apps
# Redirect URI a registrar: ${NEXTAUTH_URL}/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# 009-auth-web (PR1) â€” Credencial compartida BFFâ†”backend para POST
# /api/v1/auth/web-signup. Debe coincidir byte-por-byte con
# `Auth:BffApiKey` del backend (env var `Auth__BffApiKey`).
# **Server-side ONLY** â€” NUNCA uses `NEXT_PUBLIC_BFF_API_KEY` (serÃ­a leak
# al bundle del cliente). El BFF (`app/api/auth/web-signup/route.ts`) y
# el adapter (`lib/api/auth-adapter.ts`) la leen con `process.env.BFF_API_KEY`.
# Si estÃ¡ vacÃ­a, el adapter falla fail-closed (no emite request) con
# AuthAdapterError("BFF_AUTH_NOT_CONFIGURED").
BFF_API_KEY=replace-me-with-shared-secret-from-api-Auth__BffApiKey

# TTL del cache in-memory de JWTs backend en el BFF (segundos). Default 300 (5 min).
JWT_CACHE_TTL_SECONDS=300

# OrÃ­genes permitidos para HMR/WebSocket en modo desarrollo.
# Separa mÃºltiples valores con comas. Default: 127.0.0.1
ALLOWED_DEV_ORIGINS=127.0.0.1

# Editor estructurado JSON Resume (Constitution Art. I â€” confianza por campo).
# "true" (default) usa `BasicsForm` / `WorkList` / `EducationList` /
# `SkillsByCategory` con `promoteConfidence` al guardar. "false" vuelve al
# editor markdown legacy (8 secciones tipadas).
NEXT_PUBLIC_STRUCTURED_INPUT=true
