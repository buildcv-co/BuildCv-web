# URL del backend .NET consumido por el BFF (Route Handlers), server-to-server.
# En producción apunta al backend desplegado (Render/Railway/Azure).
BACKEND_URL=http://localhost:5080

# Habilita el widget de Wompi (012-wompi) en el frontend. Debe coincidir con
# Wompi:Enabled del backend; si está apagado, /api/payments/* devuelve 404.
NEXT_PUBLIC_WOMPI_ENABLED=false

# Modo local: salta el flujo OAuth y auto-autentica como usuario fijo
# (local@buildcv.dev con 1000 créditos). Requiere que el backend tenga
# LocalAuth:Enabled=true (appsettings.Development.json) y que NEXTAUTH_SECRET
# coincida con NextAuth:SigningKey del backend.
# Déjalo en "false" para builds de staging/producción.
NEXT_PUBLIC_LOCAL_MODE=true

# 013.2-web-jwt-cookie — NextAuth.js (firmar/verificar session JWT).
# NEXTAUTH_SECRET DEBE coincidir byte-por-byte con JwtSettings:Secret del API
# (appsettings.json) o con NextAuth:SigningKey. Mínimo 32 caracteres (HS256).
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=local-dev-secret-min-32-chars-for-testing-only

# Issuer y audience firmados en el JWT HS256 para /api/v1/auth/session.
# Deben coincidir con NextAuth:Issuer y NextAuth:Audience del backend.
NEXTAUTH_ISSUER=buildcv-web
NEXTAUTH_AUDIENCE=buildcv-api

# Google OAuth provider (NextAuth). Obtener en https://console.cloud.google.com/apis/credentials
# Redirect URI a registrar: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth provider (NextAuth). Obtener en https://www.linkedin.com/developers/apps
# Redirect URI a registrar: ${NEXTAUTH_URL}/api/auth/callback/linkedin
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# TTL del cache in-memory de JWTs backend en el BFF (segundos). Default 300 (5 min).
JWT_CACHE_TTL_SECONDS=300

# Orígenes permitidos para HMR/WebSocket en modo desarrollo.
# Separa múltiples valores con comas. Default: 127.0.0.1
ALLOWED_DEV_ORIGINS=127.0.0.1
